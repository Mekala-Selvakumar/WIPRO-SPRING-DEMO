	<bean id="dept1" class="com.springcore.model.Department">
	   <property name="departmentId" value="20" />
	   <property name="departmentName" value="Finance" />
	   <property name="location" value="Chennai" />
	 </bean>
	 <bean id="employee1" class="com.springcore.model.Employee" autowire="byName">
	  <property name="employeeId" value="12345"/>
	  	  <property name="employeeName" value="Tom"/>
	  	  <property name="salary" value="25000"/>
 	  </bean>
 	<bean id="employee2" class="com.springcore.model.Employee" autowire="byType">
	  <property name="employeeId" value="334455"/>
	  	  <property name="employeeName" value="Jerry"/>
	  	  <property name="salary" value="25000"/>
 	  </bean>
  	  <bean id="cust1" class="com.springcore.model.Customer" >
 	   <constructor-arg name="customerId" value="88899" />
 	  <constructor-arg  name="customerName" value="RajaRajan" />
 	  <constructor-arg name="emailId" value="raja@gmail.com" />
  	  </bean>
  	  <!--autowire="constructor"   - byType  -->
  	  <bean id="account1" class="com.springcore.model.Account"   
  	  autowire="constructor" >
  	    <constructor-arg  name="accountNumber" value="1234567" />
  	    <constructor-arg name="accountType" value="Savings" />
  	    <constructor-arg  name="balance"  value="50000"/>
    	  </bean>

 	 

</beans>